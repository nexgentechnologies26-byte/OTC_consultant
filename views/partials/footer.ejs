<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <% if (data.brand.logoUrl) { %>
        <img class="brand-logo-img brand-logo-img-footer" src="<%= data.brand.logoUrl %>" alt="<%= data.brand.name %> logo">
      <% } else { %>
        <span class="brand-mark"><%= data.brand.logoInitials %></span>
      <% } %>
      <p class="footer-tagline"><%= data.brand.tagline %></p>
      <div class="social-links">
        <% if (data.contact.facebook) { %>
          <a href="<%= data.contact.facebook %>" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7.5h2.5l.4-3H13.5V8.4c0-.87.24-1.46 1.5-1.46h1.6V4.3c-.28-.04-1.23-.12-2.34-.12-2.32 0-3.9 1.42-3.9 4.02V10.5H8v3h2.36V21h3.14z"/></svg>
          </a>
        <% } %>
        <% if (data.contact.instagram) { %>
          <a href="<%= data.contact.instagram %>" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1"/></svg>
          </a>
        <% } %>
        <% if (data.contact.linkedin) { %>
          <a href="<%= data.contact.linkedin %>" aria-label="LinkedIn" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.94 8.5H3.56V20h3.38V8.5zM5.25 3.5a1.96 1.96 0 1 0 0 3.92 1.96 1.96 0 0 0 0-3.92zM20.44 20h-3.37v-6.06c0-1.44-.03-3.3-2.01-3.3-2.02 0-2.33 1.58-2.33 3.2V20H9.36V8.5h3.24v1.57h.05c.45-.86 1.56-1.77 3.2-1.77 3.43 0 4.06 2.26 4.06 5.2V20z"/></svg>
          </a>
        <% } %>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <a href="/services">Services</a>
      <a href="/contact">Contact Us</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <a href="tel:<%= data.contact.phone.replace(/\s/g,'') %>"><%= data.contact.phone %></a>
      <a href="mailto:<%= data.contact.email %>"><%= data.contact.email %></a>
      <span><%= data.contact.address %></span>
      <span><%= data.contact.officeHours %></span>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>&copy; <%= new Date().getFullYear() %> <%= data.brand.name %>. All rights reserved.</span>
    </div>
  </div>
</footer>
